generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Program {
  id           String   @id @default(uuid()) @map("program_id") @db.Uuid
  programName  String   @unique @map("program_name") @db.VarChar(100)
  displayOrder Int      @default(1) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  code         String   @unique @db.VarChar(20)
  users        User[]

  @@index([displayOrder])
  @@index([isActive])
  @@map("programs")
}

model Category {
  id            String        @id @default(uuid()) @map("category_id") @db.Uuid
  categoryName  String        @unique @map("category_name") @db.VarChar(100)
  categoryIcon  String?       @map("category_icon") @db.VarChar(100)
  displayOrder  Int           @default(1) @map("display_order")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  code          String        @unique @db.VarChar(30)
  subcategories SubCategory[]

  @@index([displayOrder])
  @@index([isActive])
  @@map("categories")
}

model SubCategory {
  id              String    @id @default(uuid()) @map("subcategory_id") @db.Uuid
  categoryId      String    @map("category_id") @db.Uuid
  subcategoryName String    @map("subcategory_name") @db.VarChar(100)
  displayOrder    Int       @default(1) @map("display_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  code            String    @unique @db.VarChar(50)
  icon            String?   @db.VarChar(50)
  products        Product[]
  category        Category  @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, subcategoryName])
  @@index([displayOrder])
  @@index([isActive])
  @@map("subcategories")
}

model User {
  id               String            @id @default(uuid()) @map("user_id") @db.Uuid
  bitEmail         String            @unique @map("bit_email") @db.VarChar(255)
  passwordHash     String            @map("password_hash")
  fullName         String            @map("full_name") @db.VarChar(120)
  role             UserRole          @default(USER)
  programId        String            @map("program_id") @db.Uuid
  academicYear     Int               @map("academic_year")
  whatsappNumber   String            @map("whatsapp_number") @db.VarChar(15)
  hostel           String?           @db.VarChar(100)
  profilePhotoUrl  String?           @map("profile_photo_url")
  emailVerified    Boolean           @default(false) @map("email_verified")
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  otpVerifications OTPVerification[]
  products         Product[]
  program          Program           @relation(fields: [programId], references: [id])

  @@index([programId])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model OTPVerification {
  id          String     @id @default(uuid()) @map("otp_id") @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  otpHash     String     @map("otp_hash")
  purpose     OtpPurpose
  expiresAt   DateTime   @map("expires_at")
  isUsed      Boolean    @default(false) @map("is_used")
  resendCount Int        @default(0) @map("resend_count")
  createdAt   DateTime   @default(now()) @map("created_at")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([purpose])
  @@index([expiresAt])
  @@index([isUsed])
  @@map("otp_verifications")
}

model Product {
  id               String           @id @default(uuid()) @map("product_id") @db.Uuid
  listingNumber    BigInt           @unique @map("listing_number")
  sellerId         String           @map("seller_id") @db.Uuid
  subcategoryId    String           @map("subcategory_id") @db.Uuid
  title            String           @db.VarChar(150)
  description      String
  price            Decimal          @db.Decimal(10, 2)
  condition        ProductCondition
  purchaseYear     Int?             @map("purchase_year")
  reasonForSelling String?          @map("reason_for_selling")
  negotiable       Boolean          @default(false)
  status           ProductStatus    @default(AVAILABLE)
  expiresAt        DateTime         @map("expires_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")
  images           ProductImage[]
  seller           User             @relation(fields: [sellerId], references: [id])
  subcategory      SubCategory      @relation(fields: [subcategoryId], references: [id])

  @@index([sellerId])
  @@index([subcategoryId])
  @@index([status])
  @@index([price])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("products")
}

model ProductImage {
  id           String   @id @default(uuid()) @map("image_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  imageUrl     String   @map("image_url")
  displayOrder Int      @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, displayOrder])
  @@index([productId])
  @@index([displayOrder])
  @@map("product_images")
}

enum UserRole {
  USER
  ADMIN
}

enum ProductCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ProductStatus {
  AVAILABLE
  SOLD
  EXPIRED
}

enum OtpPurpose {
  REGISTRATION
  PASSWORD_RESET
}
